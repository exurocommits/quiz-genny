# LLM Provider Configuration
LLM_PROVIDER=openai

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-nano-2025-08-07

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Pricing Configuration (Monthly prices in USD)
PRICE_FREE=0
PRICE_PRO=19
PRICE_TEAM=49

# Optional: Google Slides API
GOOGLE_CLIENT_EMAIL=your_google_client_email_here
GOOGLE_PRIVATE_KEY=your_google_private_key_here

# Optional: Tavily API for fact verification
# TAVILY_API_KEY=your_tavily_api_key_here
